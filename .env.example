# Apār Dashboard — env registry
# Copy to .env.local and fill in. Never commit .env.local.

# ── Database (Postgres via Supabase) ───────────────────────────────────────
# Pooled connection for the running app.
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres
# Direct (non-pooled) connection used by drizzle-kit for migrations.
DIRECT_URL=postgres://postgres:postgres@localhost:54322/postgres

# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser, never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# ── App ────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ── Email (transactional, via Resend) ──────────────────────────────────────
# Used by the activity digest + billing reminders. Get a key at resend.com.
# EMAIL_FROM must be a Resend-verified domain sender; for testing you may use
# "onboarding@resend.dev" (delivers only to the Resend account owner).
RESEND_API_KEY=
EMAIL_FROM="Apār One <reports@yourdomain.com>"
# Optional — defaults to "resend".
EMAIL_PROVIDER=resend

# ── Cron (shared secret for scheduled jobs) ────────────────────────────────
# Required by /api/cron/billing-reminders and /api/cron/activity-digest.
# Point a scheduler (Vercel Cron / Supabase pg_cron) at those URLs with header
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# ── OpenRouter / extraction LLM (server-only) ──────────────────────────────
OPENROUTER_API_KEY=

# Per-doc-type model overrides — leave unset to use defaults from src/lib/llm/config.ts.
MODEL_VENDOR_INVOICE=
MODEL_CLIENT_INVOICE=
MODEL_EXPENSE_RECEIPT=
MODEL_PAYSLIP=
MODEL_SALARY_INPUT=
MODEL_FALLBACK=
