# Apār Dashboard — env registry
# Copy to .env.local and fill in. Never commit .env.local.

# ── Database (Postgres via Supabase) ───────────────────────────────────────
# Pooled connection for the running app.
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres
# Direct (non-pooled) connection used by drizzle-kit for migrations.
DIRECT_URL=postgres://postgres:postgres@localhost:54322/postgres

# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser, never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# ── App ────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ── Sessions (HMAC secret for the signed, httpOnly session cookies) ─────────
# Signs the employee portal session (`apar_emp_uid`) and, if set, the OS
# session too. Use one long random string per deployment. If unset the code
# falls back to OS_SESSION_SECRET, then a constant — set this in production.
APP_SESSION_SECRET=
# Optional dedicated secret for the /os lock-screen session (`apar_os_uid`).
OS_SESSION_SECRET=

# ── Email (sends via your Google / Google Workspace account over SMTP) ──────
# Used by the activity digest. Requires 2-Step Verification on the account;
# generate a 16-char App Password at https://myaccount.google.com/apppasswords
# (Workspace admins must allow App Passwords). Never your normal password.
GMAIL_USER=you@your-workspace-domain.com
GMAIL_APP_PASSWORD=
# Optional display name on the From line (address is always GMAIL_USER).
EMAIL_FROM_NAME="Apār One"

# ── Cron (shared secret for scheduled jobs) ────────────────────────────────
# Required by /api/cron/billing-reminders and /api/cron/activity-digest.
# Point a scheduler (Vercel Cron / Supabase pg_cron) at those URLs with header
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# ── OpenRouter / extraction LLM (server-only) ──────────────────────────────
OPENROUTER_API_KEY=

# Per-doc-type model overrides — leave unset to use defaults from src/lib/llm/config.ts.
MODEL_VENDOR_INVOICE=
MODEL_CLIENT_INVOICE=
MODEL_EXPENSE_RECEIPT=
MODEL_PAYSLIP=
MODEL_SALARY_INPUT=
MODEL_FALLBACK=
